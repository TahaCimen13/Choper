rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Ürünler: herkes okuyabilir, sadece admin yazabilir
    match /products/{productId} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.token.email == 'cimentahayasin@gmail.com';
    }

    // Sepet: kullanıcı sadece kendi sepetine erişebilir
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;
    }

    // Mesajlar: herkes yazabilir, sadece admin okuyabilir
    match /messages/{msgId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null
                                  && request.auth.token.email == 'cimentahayasin@gmail.com';
    }

    // Kullanıcı profilleri: kullanıcı kendi profilini yönetir, admin hepsini yönetir
    match /userProfiles/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read, write: if request.auth != null && request.auth.token.email == 'cimentahayasin@gmail.com';
    }
  }
}
